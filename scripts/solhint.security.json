{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", "^0.8.26"],
    "reason-string": "off",
    "func-visibility": ["error", { "ignoreConstructors": true }],
    "func-name-mixedcase": "off",
    "private-vars-leading-underscore": "off",
    "ordering": "off",
    "max-states-count": "off"
  }
}
